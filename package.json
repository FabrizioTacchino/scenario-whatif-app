{
  "name": "analisi-scenari-vdp",
  "version": "1.0.63",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "keygen:ui": "electron tools/keygen-main.cjs",
    "electron:dev": "electron . --dev",
    "electron:start": "vite build && electron .",
    "electron:build": "vite build && electron-builder",
    "release": "vite build && electron-builder --publish always"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.0",
    "chart.js": "^4.4.0",
    "chartjs-plugin-datalabels": "^2.2.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "vite": "^6.0.0",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.scenariowhatif.app",
    "productName": "Analisi Scenari VDP",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs",
      "logoVDP.png"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "FabrizioTacchino",
        "repo": "scenario-whatif-app",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "logoVDP.png"
    },
    "nsis": {
      "oneClick": true,
      "allowElevation": true,
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh"
    }
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  }
}
